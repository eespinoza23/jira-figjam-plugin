{
  "name": "jira-figjam-plugin",
  "version": "0.2.1",
  "description": "Jira Multi-Import plugin for FigJam with Vercel serverless backend",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"vercel dev\" \"npm run plugin:dev\"",
    "dev:vercel": "vercel dev",
    "dev:plugin": "vite --host",
    "build": "node build.js",
    "build:vercel": "tsc --project api/tsconfig.json",
    "preview": "vite preview",
    "deploy": "vercel"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "express": "^4.21.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.2"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^6.0.0",
    "vercel": "^34.2.0",
    "concurrently": "^8.2.2"
  }
}
