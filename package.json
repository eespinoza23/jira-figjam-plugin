{
  "name": "jira-figjam-plugin",
  "version": "0.2.1",
  "description": "Jira Multi-Import plugin for FigJam with Vercel serverless backend",
  "scripts": {
    "dev": "concurrently \"vercel dev\" \"npm run plugin:dev\"",
    "dev:vercel": "vercel dev",
    "dev:plugin": "vite --host",
    "build": "tsc && vite build",
    "build:vercel": "tsc --project api/tsconfig.json",
    "preview": "vite preview",
    "deploy": "vercel"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.5.7",
    "@vitejs/plugin-react": "^4.1.1",
    "vite": "^5.0.0",
    "vercel": "^33.1.0",
    "concurrently": "^8.2.2"
  }
}
